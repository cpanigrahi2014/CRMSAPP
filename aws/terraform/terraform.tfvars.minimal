# ─────────────────────────────────────────────────────────────────────────────
# MINIMUM COST testing config for ECS deployment (5 users)
# Estimated: ~$180-220/month (use terraform-minimal/ for $20-35/month instead)
# ─────────────────────────────────────────────────────────────────────────────

aws_region  = "us-east-1"
environment = "test"

# RDS — smallest instance with free tier eligible
db_instance_class    = "db.t3.micro"    # $13/mo (free first 12 months)
db_allocated_storage = 20
db_master_username   = "postgres"
db_master_password   = "CHANGE_ME_strong_password_here"
db_multi_az          = false            # Single AZ only for testing

# ElastiCache — smallest available
redis_node_type = "cache.t3.micro"      # $12/mo

# MSK Kafka — smallest available
kafka_instance_type = "kafka.t3.small"  # $45/mo each
kafka_broker_count  = 2                 # Minimum 2 required by MSK

# ECS — absolute minimum per service
service_cpu    = 256    # 0.25 vCPU ($3/mo per service)
service_memory = 512    # 0.5 GB
frontend_cpu   = 256
frontend_memory = 512
desired_count  = 1      # Single task per service

# Secrets
jwt_secret    = "CHANGE_ME_your_jwt_secret_base64_here"
llm_api_key   = "sk-proj-your-openai-key-here"
llm_model     = "gpt-4o"
llm_base_url  = "https://api.openai.com/v1"

# Mail (optional)
mail_host     = "smtp.gmail.com"
mail_port     = 587
mail_username = "noreply@example.com"
mail_password = ""

# Domain (leave empty to skip)
domain_name = ""
